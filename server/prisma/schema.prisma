generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("CUSTOMER")
  phone     String?
  company   String?
  isActive  Boolean  @default(true)

  // 2FA fields
  twoFactorEnabled   Boolean   @default(false)
  twoFactorSecret    String?
  emailVerified      Boolean   @default(false)
  verificationCode   String?
  codeExpires        DateTime?
  resetToken         String?
  resetExpires       DateTime?

  // KYC
  kycStatus String?
  kycFile   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // RELATIONS
  auditLogs          AuditLog[]           @relation("UserAuditLogs")
  partnerDetails     PartnerDetails?
  userVehicles       Vehicle[]            @relation("UserVehicles")
  subscriptions      Subscription[]
  kycHistory         KycHistory[]
  bookings           Booking[]
  contactMessages    ContactMessage[]
}

model Booking {
  id              String   @id @default(cuid())
  userId          String?
  fullName        String
  email           String
  phone           String
  pickupLocation  String
  destination     String?
  carType         String
  carTypeName     String
  carDailyRate    Float
  serviceType     String?
  pickupDate      DateTime
  pickupTime      String
  passengers      Int      @default(1)
  specialRequests String?
  
  // Driver option
  driverRequired         Boolean  @default(false)
  driverLicenseUrl       String?
  driverLicenseNumber    String?
  driverLicenseVerified  Boolean  @default(false)
  
  // Face verification
  selfieUrl        String?
  faceVerified     Boolean  @default(false)
  faceMatchScore   Float?
  
  // Documents
  nepabillUrl      String?
  
  // Pricing
  totalDays        Int
  subtotal         Float
  vat              Float
  tax              Float
  driverFee        Float?
  grandTotal       Float
  
  // Status
  status           String   @default("pending")
  paymentStatus    String   @default("unpaid")
  paymentReference String?
  paymentUrl       String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  user User? @relation(fields: [userId], references: [id])
}

model Vehicle {
  id          String   @id @default(uuid())
  title       String
  description String?
  dailyRate   Float
  imageUrl    String?
  available   Boolean  @default(true)
  ownerId     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner User? @relation("UserVehicles", fields: [ownerId], references: [id])
}

model NewsletterSubscriber {
  id             String   @id @default(cuid())
  email          String   @unique
  subscribedAt   DateTime @default(now()) @map("subscribed_at")
  unsubscribedAt DateTime? @map("unsubscribed_at")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("newsletter_subscribers")
}

model KycHistory {
  id        String   @id @default(uuid())
  userId    String
  filename  String
  status    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  details   String?
  createdAt DateTime @default(now())

  user User @relation("UserAuditLogs", fields: [userId], references: [id])
}

model PartnerDetails {
  id         String   @id @default(uuid())
  userId     String   @unique
  company    String
  phone      String?
  cacNumber  String?
  fleetSize  String?
  address    String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Subscription {
  id         String   @id @default(uuid())
  userId     String
  plan       String
  status     String   @default("ACTIVE")

  startDate  DateTime @default(now())
  endDate    DateTime

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
}