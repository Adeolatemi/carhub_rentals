generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("CUSTOMER")
  phone     String?
  company   String?
  isActive  Boolean  @default(true)

  // 2FA fields
  twoFactorEnabled   Boolean   @default(false)
  twoFactorSecret    String?
  // AUTH / SECURITY
  emailVerified    Boolean   @default(false)
  verificationCode String?
  codeExpires      DateTime?
  resetToken       String?
  resetExpires     DateTime?

  // KYC
  kycStatus String?
  kycFile   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // RELATIONS
  bookings           CarBooking[]
  orders             Order[]
  auditLogs          AuditLog[]           @relation("UserAuditLogs")
  partnerDetails     PartnerDetails?
  userVehicles       Vehicle[]            @relation("UserVehicles")
  subscriptions      Subscription[]
  kycHistory         KycHistory[]
  enhancedBookings   EnhancedBooking[]
  contactMessages    ContactMessage[]
}

model NewsletterSubscriber {
  id             String   @id @default(cuid())
  email          String   @unique
  subscribedAt   DateTime @default(now()) @map("subscribed_at")
  unsubscribedAt DateTime? @map("unsubscribed_at")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("newsletter_subscribers")
}

model CarBooking {
  id              String   @id @default(uuid())
  fullName        String
  phone           String
  email           String
  pickupLocation  String
  dropoffLocation String
  startDate       DateTime
  endDate         DateTime
  totalAmount     Float    @default(0)
  status          String   @default("PENDING")

  userId    String?
  vehicleId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User?    @relation(fields: [userId], references: [id])
  vehicle Vehicle? @relation("BookingVehicle", fields: [vehicleId], references: [id])
}

model Order {
  id              String   @id @default(uuid())
  userId          String
  vehicleId       String?

  fullName        String?
  phone           String?
  email           String?
  pickupLocation  String?
  dropoffLocation String?
  pickupDate      DateTime?
  dropoffDate     DateTime?

  total           Float    @default(0)
  status          String   @default("PENDING")
  adminNote       String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  vehicle Vehicle? @relation("OrderVehicle", fields: [vehicleId], references: [id])
}

model Vehicle {
  id          String   @id @default(uuid())
  title       String
  description String?
  dailyRate   Float
  imageUrl    String?
  available   Boolean  @default(true)

  ownerId     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner    User?        @relation("UserVehicles", fields: [ownerId], references: [id])
  bookings CarBooking[] @relation("BookingVehicle")
  orders   Order[]      @relation("OrderVehicle")
  enhancedBookings EnhancedBooking[]
}

model KycHistory {
  id        String   @id @default(uuid())
  userId    String
  filename  String
  status    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  details   String?
  createdAt DateTime @default(now())

  user User @relation("UserAuditLogs", fields: [userId], references: [id])
}

model PartnerDetails {
  id         String   @id @default(uuid())
  userId     String   @unique
  company    String
  phone      String?
  cacNumber  String?
  fleetSize  String?
  address    String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Subscription {
  id         String   @id @default(uuid())
  userId     String
  plan       String
  status     String   @default("ACTIVE")

  startDate  DateTime @default(now())
  endDate    DateTime

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// ============================================
// ENHANCED BOOKING & VERIFICATION MODELS
// ============================================

model EnhancedBooking {
  id              String   @id @default(cuid())
  userId          String
  vehicleId       String
  startDate       DateTime
  endDate         DateTime
  totalDays       Int
  dailyRate       Float
  subtotal        Float
  vat             Float
  tax             Float
  driverFee       Float?    // Only defined once!
  grandTotal      Float
  status          String   @default("pending")      // pending, verified, confirmed, cancelled
  paymentStatus   String   @default("unpaid")       // unpaid, paid, refunded
  paymentIntentId String?
  
  // Documents
  idDocument      String?   // URL to ID document
  utilityBill     String?   // URL to NEPA bill (3 months)
  driverLicense   String?   // URL to driver's license
  selfieImage     String?   // URL to selfie
  
  // Verification
  verificationStatus String @default("pending")     // pending, verified, failed
  verificationData   Json?   // Store verification results
  livenessData       Json?   // Store liveness verification data
  
  // Driver option
  driverRequired  Boolean  @default(false)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  user   User     @relation(fields: [userId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  verificationLogs VerificationLog[]
  utilityBillVerifications UtilityBillVerification[]
}

model VerificationLog {
  id          String   @id @default(cuid())
  bookingId   String
  type        String   // id_check, liveness, license_check, address_check
  status      String   // success, failed, pending
  confidence  Float?
  metadata    Json?    // Store detailed verification results
  createdAt   DateTime @default(now())
  
  booking EnhancedBooking @relation(fields: [bookingId], references: [id])
}

model UtilityBillVerification {
  id          String   @id @default(cuid())
  bookingId   String
  documentUrl String
  address     String   // extracted address from bill
  issueDate   DateTime?
  verifiedAt  DateTime?
  status      String   @default("pending")  // pending, verified, rejected
  rejectionReason String?
  
  booking EnhancedBooking @relation(fields: [bookingId], references: [id])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    String   @default("pending")   // pending, read, replied
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
}