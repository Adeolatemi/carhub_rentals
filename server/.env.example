# Database
DATABASE_URL="file:./dev.db"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this

# Server
PORT=4000
NODE_ENV=development

# Frontend Base URL (for email links)
FRONTEND_BASE=http://localhost:5173

# Webhook Base URL (for payment callbacks)
WEBHOOK_BASE=http://localhost:4000

# Monnify Payment Gateway
# Set MONNIFY_SANDBOX=true for testing
MONNIFY_SANDBOX=true
MONNIFY_API_KEY=your-monify-api-key
MONNIFY_SECRET_KEY=your-monify-secret-key
MONNIFY_CONTRACT_CODE=your-monify-contract-code
MONNIFY_WEBHOOK_SECRET=your-monify-webhook-secret

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@carhub.example

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# SmileID (for KYC)
SMILE_ID_API_KEY=your-smile-id-api-key
SMILE_ID_PARTNER_ID=your-smile-id-partner-id

